---
import { type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import { ArrowLeft, ExternalLink } from "@lucide/astro";

import GitHub from "../assets/Github.svg";
import "../styles/global.css";

type Props = CollectionEntry<"projects">["data"];

const {
  title,
  description,
  heroImage,
  year,
  technologies,
  role,
  liveLink,
  sourceCodeLink,
} = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead
      title={`Daniel Kulichkov - ${title} project`}
      description={description}
    />
  </head>
  <body>
    <nav
      class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border"
    >
      <div
        class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center"
      >
        <a
          href="/"
          class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors"
        >
          <ArrowLeft size={18} />
          <span class="text-sm font-medium">Back</span>
        </a>
      </div>
    </nav>

    <main class="min-h-screen bg-background">
      <article class="pt-32 pb-20 px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <header class="mb-16">
            {
              year && role && (
                <div class="flex items-center gap-4 text-sm text-muted-foreground mb-3">
                  {year && <span>{year}</span>}
                  {year && role && (
                    <span class="w-1 h-1 rounded-full bg-muted-foreground" />
                  )}
                  {role && <span>{role}</span>}
                </div>
              )
            }
            <h1
              class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground mb-2 text-balance"
            >
              {title}
            </h1>

            <p class="text-xl text-muted-foreground leading-relaxed max-w-2xl">
              {description}
            </p>
          </header>

          {
            heroImage && (
              <div class="w-full aspect-video rounded-lg mb-16 border border-border">
                <Image src={heroImage} alt={title} />
              </div>
            )
          }

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-16">
            <div class="lg:col-span-2 markdown-content">
              <slot />
            </div>

            <aside class="space-y-8">
              <div>
                <h2
                  class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-4"
                >
                  Technologies
                </h2>
                <div class="flex flex-wrap gap-2">
                  {
                    technologies.map((technology) => (
                      <span class="px-3 py-1.5 bg-muted text-muted-foreground text-sm font-medium rounded-md">
                        {technology}
                      </span>
                    ))
                  }
                </div>
              </div>

              {/* Links */}
              <div>
                <h2
                  class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-4"
                >
                  Links
                </h2>
                <div class="flex flex-col gap-3">
                  <a
                    href={liveLink}
                    target="_blank"
                    class="flex items-center gap-2 text-foreground hover:text-primary transition-colors"
                  >
                    <ExternalLink class="w-4 h-4" />
                    <span class="text-sm font-medium">Live Demo</span>
                  </a>
                  {
                    sourceCodeLink && (
                      <a
                        href={sourceCodeLink}
                        target="_blank"
                        class="flex items-center gap-2 text-foreground hover:text-primary transition-colors"
                      >
                        <GitHub class="w-4 h-4" />
                        <span class="text-sm font-medium">Source Code</span>
                      </a>
                    )
                  }
                </div>
              </div>
            </aside>
          </div>

          <div class="pt-8 border-t border-border">
            <a
              href="/"
              class="inline-flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors"
            >
              <ArrowLeft size={16} />
              <span class="text-sm font-medium">Back to all projects</span>
            </a>
          </div>
        </div>
      </article>
    </main>
  </body><Footer />
</html>
