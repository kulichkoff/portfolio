---
import { CodeXml, ShieldCheck, Zap } from "@lucide/astro";
---

<section class="py-20 sm:py-32 px-4 sm:px-6 lg:px-8 bg-background">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16">
      <h2
        id="about"
        class="text-sm font-semibold text-primary uppercase tracking-wider mb-2"
      >
        About Me
      </h2>
      <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-6">
        Passionate developer with a focus on creating exceptional digital
        products.
      </h2>
      <p class="text-lg text-muted-foreground leading-relaxed text-balance">
        I&apos;m Daniel Kulichkov, a full-stack developer with 5+ years of
        experience building software products that users love and companies
        trust.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 mb-20">
      <div class="space-y-6">
        <div>
          <h3 class="text-xl font-semibold text-foreground mb-3">My Journey</h3>
          <p class="text-muted-foreground leading-relaxed">
            I started coding in 2017 and fell in love with solving problems
            through elegant code. Over the years, I&apos;ve worked with startups
            and enterprises, learning that great software is about understanding
            user needs and delivering solutions that matter.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold text-foreground mb-3">
            What Drives Me
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            I&apos;m obsessed with building products that are user-friendly,
            performant, and secure on the inside. Clean code, thoughtful design,
            and continuous learning are at the core of everything I do.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold text-foreground mb-3">
            Outside of Code
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            When I&apos;m not coding, you&apos;ll find me exploring new
            technologies, reading books, or enjoing gongfu cha. I believe in
            building a community and sharing knowledge.
          </p>
        </div>
      </div>

      <div class="space-y-6">
        {
          [
            {
              icon: CodeXml,
              title: "Quality Code",
              description:
                "Writing clean, maintainable code that stands the test of time.",
            },
            {
              icon: ShieldCheck,
              title: "Safety Matters",
              description:
                "Building safe, secure software that protects user data and business interests.",
            },
            {
              icon: Zap,
              title: "Performance First",
              description:
                "Building fast, efficient applications that provide seamless experiences.",
            },
          ].map(({ icon: Icon, title, description }) => (
            <div class="p-5 rounded-lg bg-card border border-border hover:border-primary/50 transition-colors duration-300">
              <div class="flex items-start gap-4">
                <Icon class="w-6 h-6 text-primary shrink-0 mt-1" />
                <div>
                  <h4 class="font-semibold text-foreground mb-2">{title}</h4>
                  <p class="text-sm text-muted-foreground">{description}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mb-20">
      <h3 class="text-2xl font-semibold text-foreground mb-8">
        Skills & Expertise
      </h3>
      <div class="grid sm:grid-cols-3 gap-6">
        {
          [
            {
              category: "Frontend",
              skills: [
                "React",
                "Svelte",
                "Angular",
                "TypeScript",
                "Tailwind CSS",
              ],
            },
            {
              category: "Backend",
              skills: [
                "Node.js",
                "Go",
                "Rust",
                "gRPC",
                "PostgreSQL",
                "Kafka",
                "API Design",
              ],
            },
            {
              category: "Tools & Others",
              skills: ["Git", "CI/CD", "Docker", "DevOps", "AWS", "Testing"],
            },
          ].map(({ category, skills }) => (
            <div class="p-6 rounded-lg bg-card border border-border max-h-fit">
              <h4 class="font-semibold text-foreground mb-4">{category}</h4>
              <ul class="space-y-2">
                {skills.map((skill) => (
                  <li class="text-sm text-muted-foreground flex items-center gap-2 hover:text-primary transition-colors">
                    <div class="w-1.5 h-1.5 rounded-full bg-primary" />
                    {skill}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
