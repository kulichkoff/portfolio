---
import GitHub from "../assets/GitHub.svg";
import Medium from "../assets/Medium.svg";

import { Mail } from "@lucide/astro";

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: "GitHub",
    icon: GitHub,
    url: "https://github.com/kulichkoff",
    label: "Visit GitHub profile",
  },
  {
    name: "Medium",
    icon: Medium,
    url: "https://medium.com/@danchick03",
    label: "Visit Medium profile",
  },
  {
    name: "Email",
    icon: Mail,
    url: "mailto:danchick03@gmail.com",
    label: "Send an email",
  },
];

const navigationLinks = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/#projects" },
  { label: "About", href: "#about" },
  { label: "Contact", href: "#contact" },
];
---

<footer class="border-t border-border bg-background/50 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <div class="md:col-span-1">
        <h3 class="text-lg font-bold text-foreground mb-2">Daniel Kulichkov</h3>
        <p class="text-sm text-muted-foreground mb-4">
          Full-stack developer crafting digital experiences with modern
          technologies.
        </p>
        <p class="text-xs text-muted-foreground">Based in the digital realm</p>
      </div>

      <div class="md:col-span-1">
        <h4 class="font-semibold text-foreground mb-4">Navigation</h4>
        <ul class="space-y-2">
          {
            navigationLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground hover:text-primary transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Contact Section */}
      <div class="md:col-span-1">
        <h4 class="font-semibold text-foreground mb-4">Get in Touch</h4>
        <div class="space-y-2">
          <p class="text-sm">
            <a
              href="mailto:danchick03@gmail.com"
              class="text-muted-foreground hover:text-primary transition-colors duration-200"
            >
              danchick03@gmail.com
            </a>
          </p>
          <p class="text-sm text-muted-foreground">
            Available for freelance projects and collaborations
          </p>
        </div>
      </div>

      <div class="md:col-span-1">
        <h4 class="font-semibold text-foreground mb-4">Follow</h4>
        <div class="flex gap-3">
          {
            socialLinks.map((social) => {
              const Icon = social.icon;
              return (
                <a
                  href={social.url}
                  aria-label={social.label}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="p-2 rounded-lg bg-secondary/50 hover:bg-primary/20 text-muted-foreground hover:text-primary transition-all duration-200"
                >
                  <Icon size={18} width={18} height={18} class="text-foreground" />
                </a>
              );
            })
          }
        </div>
      </div>
    </div>

    <div class="border-t border-border mb-8"></div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted-foreground text-center sm:text-left">
        &copy; {currentYear} Daniel Kulichkov. All rights reserved.
      </p>
    </div>
  </div>
</footer>
