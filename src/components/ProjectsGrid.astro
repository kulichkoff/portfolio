---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const projects = await getCollection("projects");
---

<section class="w-full py-20 px-4 sm:px-6 lg:px-8 bg-background">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16">
      <h2
        id="projects"
        class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground mb-4"
      >
        Featured Projects
      </h2>
      <p class="text-lg text-muted-foreground max-w-2xl">
        A selection of my recent work showcasing my expertise in full-stack
        development and problem-solving.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <a
            href={`/projects/${project.id}`}
            class="group relative bg-card border border-border rounded-lg overflow-hidden hover:border-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-primary/10"
          >
            <div class="h-48 w-full relative overflow-hidden">
              {project.data.heroImage && (
                <Image
                  height={192}
                  src={project.data.heroImage}
                  alt=""
                />
              )}
              <div class="absolute inset-0 bg-linear-to-br from-transparent to-black/20 group-hover:to-black/40 transition-all duration-300" />
            </div>

            <div class="p-6">
              <h3 class="text-xl font-bold text-foreground mb-2 group-hover:text-primary transition-colors">
                {project.data.title}
              </h3>
              <p class="text-muted-foreground text-sm mb-4 line-clamp-2">
                {project.data.description}
              </p>

              <div class="flex flex-wrap gap-2">
                {project.data.technologies.map((tag) => (
                  <span class="px-3 py-1 bg-muted text-muted-foreground text-xs font-medium rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
